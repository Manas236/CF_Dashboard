# ---- Cloudflare ----
# Token permission: Zone -> Analytics -> Read. Create at
# https://dash.cloudflare.com/profile/api-tokens
#
# The two sites live in SEPARATE Cloudflare accounts, so each needs its OWN
# token: set CF_API_TOKEN_<SITE> per site. CF_API_TOKEN is a shared fallback
# used for any site without its own token (fine if all zones are in one
# account). Account ID is NOT used by these analytics queries.
CF_API_TOKEN=
CF_API_TOKEN_NEWSBAND=
CF_API_TOKEN_NAVESHAHAR=
# Optional, currently unused by the analytics queries; kept for reference.
CF_ACCOUNT_ID=

# Zone IDs: Cloudflare dashboard -> select zone -> Overview -> API (right column)
CF_ZONE_ID_NEWSBAND=
CF_ZONE_ID_NAVESHAHAR=

# ---- MySQL (dedicated schema; the app never touches other databases) ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=cf_dash
MYSQL_PASSWORD=
MYSQL_DATABASE=cf_analytics

# ---- Collector ----
# How many recent hours each collector run (re-)collects. Re-collecting recent
# hours overwrites partial data and rides out missed cron runs.
COLLECT_HOURS=6
# Optional: extra bot User-Agent signatures, one per line:
# "Name|substring" or "Name|substring|type" (type: search/ai/seo/social/
# monitor/feed/script/other). Matched case-insensitively.
BOT_UA_FILE=
# GraphQL batching (defaults respect Cloudflare's per-query group budget):
# RANGE_CHUNK_HOURS=12   hours of cheap dims (totals/status/cache/country) per call
# HEAVY_BATCH_HOURS=6    hours of heavy top-Ns (paths/UAs/error paths) per call

# ---- Panels ----
# Minimum est. hits in the current window before a path can "trend".
TREND_MIN_HITS=50
# Category prefixes and article exclusions are code config (app/config.py:
# CATEGORY_RULES, ARTICLE_EXCLUDE_*) — edit them there.

# ---- Dashboard ----
DASH_HOST=127.0.0.1
DASH_PORT=5000
FLASK_DEBUG=0

# ---- Auth / login gate ----
# Session signing key. Generate one:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# The single shared login.
APP_USERNAME=admin
# Password HASH (never the plaintext). Generate one:
#   python -c "from werkzeug.security import generate_password_hash as g; import getpass; print(g(getpass.getpass('Password: ')))"
APP_PASSWORD_HASH=
# Secure cookie needs HTTPS: 1 in production, 0 for local HTTP dev.
# (Defaults to 0 when FLASK_DEBUG=1, else 1.)
SESSION_COOKIE_SECURE=1
# Optional tuning:
# SESSION_LIFETIME_MINUTES=720   how long a login stays valid
# LOGIN_MAX_ATTEMPTS=5           failed tries per IP before lockout
# LOGIN_LOCKOUT_SECONDS=300      lockout window length
